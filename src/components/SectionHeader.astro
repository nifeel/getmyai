---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---
<div class="section-heading">
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
  </div>
  {description && <p class="lead" style="max-width: 44ch; margin: 0;">{description}</p>}
</div>
