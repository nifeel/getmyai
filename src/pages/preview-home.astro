---
import BaseLayout from "../layouts/BaseLayout.astro";

const models = [
  { name: "GPT", mark: "GPT", icon: "", tone: "openai" },
  { name: "Claude", mark: "C", icon: "https://cdn.simpleicons.org/anthropic/f97316", tone: "claude" },
  { name: "Gemini", mark: "G", icon: "https://cdn.simpleicons.org/googlegemini/8b5cf6", tone: "gemini" },
  { name: "DeepSeek", mark: "D", icon: "https://cdn.simpleicons.org/deepseek/2563eb", tone: "deepseek" },
  { name: "Qwen", mark: "Q", icon: "https://cdn.simpleicons.org/alibabacloud/0ea5e9", tone: "qwen" },
  { name: "Kimi", mark: "K", icon: "https://cdn.simpleicons.org/moonrepo/a78bfa", tone: "kimi" },
  { name: "Grok", mark: "X", icon: "https://cdn.simpleicons.org/x/e5e7eb", tone: "grok" },
  { name: "Mistral", mark: "M", icon: "https://cdn.simpleicons.org/mistralai/f97316", tone: "mistral" }
];

const tools = [
  { name: "Codex", mark: "CX", icon: "", tone: "openai" },
  { name: "Claude Code", mark: "CC", icon: "https://cdn.simpleicons.org/anthropic/f97316", tone: "claude" },
  { name: "OpenCode", mark: "OC", icon: "https://cdn.simpleicons.org/opencode/22d3ee", tone: "deepseek" },
  { name: "Cursor", mark: "CR", icon: "https://cdn.simpleicons.org/cursor/ffffff", tone: "grok" },
  { name: "VS Code", mark: "VS", icon: "", tone: "deepseek" },
  { name: "JetBrains", mark: "JB", icon: "https://cdn.simpleicons.org/jetbrains/ffffff", tone: "kimi" },
  { name: "Windsurf", mark: "WS", icon: "", tone: "qwen" },
  { name: "MCP", mark: "MP", icon: "https://cdn.simpleicons.org/modelcontextprotocol/22c55e", tone: "glm" }
];

const marqueeModels = [...models, ...tools, ...models, ...tools];

const products = [
  {
    name: "API Gateway",
    tag: "OpenAI Compatible",
    title: "统一 Base URL",
    text: "一个 Key 接入多家模型来源，适合脚本、SDK、聊天工具和 AI 编程工具快速迁移。"
  },
  {
    name: "Codex / Claude Code",
    tag: "Coding Tools",
    title: "面向 AI 编程优化",
    text: "围绕 Codex、Claude Code、OpenCode、Cursor 等工具整理配置教程，减少反复试错。"
  },
  {
    name: "sub2api Backend",
    tag: "Shared Route",
    title: "共享方案降本",
    text: "基于 sub2api 后台管理 Key、模型与路由，把接入成本控制在更容易接受的范围内。"
  },
  {
    name: "Docs Center",
    tag: "Static Guides",
    title: "教程长期沉淀",
    text: "把安装、代理、模型选择、常见问题整理成静态文档，方便新用户快速完成配置。"
  }
];

const features = [
  ["透明模型", "明确展示可用模型和接入方式，不用低速体验冒充高级模型。"],
  ["按量计费", "小额试用、余额扣费、用量可查，适合个人开发者长期低频使用。"],
  ["工具友好", "兼容 OpenAI API 格式，常见客户端和 IDE 插件可低成本接入。"],
  ["问题负责", "遇到鉴权、额度、响应速度或模型配置问题，有明确排查路径。"],
  ["教程完整", "把配置步骤写成文档栏目，不依赖聊天记录和口头说明。"],
  ["持续更新", "随着工具和模型变化，逐步补充 Codex、Claude Code、OpenCode 等教程。"]
];
---

<BaseLayout
  title="GetMyAI Preview | AI API Gateway"
  description="GetMyAI 另一版首页预览，参考 AI 编程 API 服务平台风格，保留 GetMyAI 的个性化定位。"
>
  <main class="preview-page">
    <section class="preview-hero">
      <a class="preview-badge" href="https://getmyai.shop">getmyai.shop · AI API Gateway</a>
      <h1>更透明的 AI 编程订阅与按量 API 中转</h1>
      <p>
        支持 GPT、Claude、Gemini、DeepSeek、Qwen 等主流模型，面向 Codex、Claude Code、
        OpenCode、Cursor 等 AI 编程工具提供统一、稳定、易配置的 OpenAI 兼容接口。
      </p>
      <div class="preview-actions">
        <a class="button" href="/docs/getting-started">开始接入</a>
        <a class="button-secondary" href="/docs">查看教程</a>
      </div>

      <div class="preview-marquee" aria-label="支持的模型和工具">
        <div class="preview-track">
          {marqueeModels.map((item) => (
            <article class={`logo-pill provider-${item.tone}`}>
              <span class="logo-mark">
                <span class="logo-fallback">{item.mark}</span>
                {item.icon && <img src={item.icon} alt={`${item.name} logo`} loading="lazy" onerror="this.hidden=true" />}
              </span>
              <strong>{item.name}</strong>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="preview-section">
      <div class="preview-section-head">
        <p class="eyebrow">Product Overview</p>
        <h2>把中转站做成可以被信任的工具入口</h2>
        <p class="lead">
          这版首页更强调“你能用它做什么”：API、AI 编程工具、sub2api 后台、教程文档四条线并列呈现。
        </p>
      </div>

      <div class="preview-products">
        {products.map((product, index) => (
          <article class="preview-product">
            <span class="preview-index">0{index + 1}</span>
            <p>{product.tag}</p>
            <h3>{product.name}</h3>
            <strong>{product.title}</strong>
            <span>{product.text}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="preview-split">
      <div>
        <p class="eyebrow">Why GetMyAI</p>
        <h2>我们从一次糟糕的中转站体验开始</h2>
        <p class="lead">
          在 Claude 周额度用尽后，我们曾临时充值第三方中转站。页面写着高级模型，
          但实际体验明显不符：响应慢、质量差、费用不透明。这就是 GetMyAI 要解决的问题。
        </p>
      </div>
      <div class="preview-proof">
        <article><strong>模型不虚标</strong><span>让用户知道自己正在调用什么。</span></article>
        <article><strong>价格可解释</strong><span>余额、扣费、用量记录尽量清楚。</span></article>
        <article><strong>信任换责任</strong><span>您给我们一分信任，我们还您一份责任。</span></article>
      </div>
    </section>

    <section class="preview-section">
      <div class="preview-section-head">
        <p class="eyebrow">Core Features</p>
        <h2>面向开发者和工具用户的核心能力</h2>
      </div>
      <div class="preview-features">
        {features.map(([title, text]) => (
          <article>
            <span class="feature-dot"></span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="preview-start">
      <div>
        <p class="eyebrow">Start Using GetMyAI</p>
        <h2>从一个 Key 和一个 Base URL 开始</h2>
        <p class="lead">
          先按教程验证接口可用，再接入 Codex、Claude Code、OpenCode 或你的项目代码。
        </p>
      </div>
      <div class="preview-actions">
        <a class="button" href="/docs/getting-started">快速开始</a>
        <a class="button-secondary" href="/pricing">查看收费模式</a>
      </div>
    </section>
  </main>

  <style>
    .preview-page {
      display: grid;
      gap: 24px;
    }

    .preview-hero {
      position: relative;
      min-height: 620px;
      padding: 72px 28px 28px;
      overflow: hidden;
      border-radius: 30px;
      border: 1px solid rgba(56, 189, 248, 0.24);
      background:
        radial-gradient(circle at 50% 8%, rgba(56, 189, 248, 0.24), transparent 28%),
        radial-gradient(circle at 18% 82%, rgba(45, 212, 191, 0.18), transparent 26%),
        linear-gradient(180deg, rgba(7, 12, 26, 0.86), rgba(10, 16, 32, 0.66));
      text-align: center;
    }

    .preview-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(56, 189, 248, 0.08) 1px, transparent 1px),
        linear-gradient(rgba(56, 189, 248, 0.08) 1px, transparent 1px);
      background-size: 44px 44px;
      mask-image: radial-gradient(circle at center, black 42%, transparent 82%);
      animation: preview-grid 18s linear infinite;
    }

    .preview-hero::after {
      content: "";
      position: absolute;
      inset: -20%;
      background: conic-gradient(from 120deg, transparent, rgba(56, 189, 248, 0.2), transparent, rgba(45, 212, 191, 0.14), transparent);
      opacity: 0.65;
      animation: preview-orbit 16s linear infinite;
    }

    .preview-hero > * {
      position: relative;
      z-index: 1;
    }

    .preview-badge {
      display: inline-flex;
      align-items: center;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid rgba(56, 189, 248, 0.34);
      background: rgba(15, 23, 42, 0.54);
      color: #67e8f9;
      font-size: 0.86rem;
      font-weight: 800;
      text-decoration: none;
    }

    .preview-hero h1 {
      width: min(900px, 100%);
      margin: 24px auto 0;
      color: #f8fbff;
      font-size: clamp(2.25rem, 6vw, 5.4rem);
      line-height: 0.98;
    }

    .preview-hero p {
      width: min(760px, 100%);
      margin: 22px auto 0;
      color: #b7c6d9;
      font-size: 1rem;
      line-height: 1.8;
    }

    .preview-actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin-top: 30px;
    }

    .preview-marquee {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 34px;
      overflow: hidden;
      padding: 12px 0;
      mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
    }

    .preview-track {
      display: flex;
      width: max-content;
      gap: 12px;
      animation: preview-scroll 34s linear infinite;
      will-change: transform;
    }

    .preview-marquee:hover .preview-track {
      animation-play-state: paused;
    }

    .preview-section,
    .preview-split,
    .preview-start {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      border: 1px solid var(--line);
      background: var(--section-bg);
      padding: 34px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .preview-section-head {
      width: min(760px, 100%);
      margin-bottom: 24px;
    }

    .preview-section-head h2,
    .preview-split h2,
    .preview-start h2 {
      font-size: clamp(1.5rem, 3vw, 2.4rem);
      line-height: 1.08;
    }

    .preview-products {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }

    .preview-product,
    .preview-proof article,
    .preview-features article {
      position: relative;
      overflow: hidden;
      min-height: 210px;
      padding: 22px;
      border-radius: 20px;
      border: 1px solid rgba(148, 163, 184, 0.18);
      background:
        linear-gradient(135deg, rgba(56, 189, 248, 0.1), transparent 48%),
        var(--surface-strong);
    }

    .preview-index {
      display: inline-flex;
      margin-bottom: 18px;
      color: var(--accent-strong);
      font-size: 0.82rem;
      font-weight: 900;
    }

    .preview-product p {
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .preview-product strong,
    .preview-product span,
    .preview-proof span,
    .preview-features p {
      display: block;
      color: var(--muted);
      line-height: 1.7;
    }

    .preview-product strong {
      margin: 14px 0 8px;
      color: var(--text);
      line-height: 1.3;
    }

    .preview-split {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 22px;
      align-items: center;
    }

    .preview-proof {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .preview-proof article {
      min-height: 150px;
    }

    .preview-proof strong {
      display: block;
      margin-bottom: 10px;
      font-size: 1.08rem;
    }

    .preview-features {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .preview-features article {
      min-height: 168px;
    }

    .feature-dot {
      display: block;
      width: 12px;
      height: 12px;
      margin-bottom: 18px;
      border-radius: 999px;
      background: #22d3ee;
      box-shadow: 0 0 0 8px rgba(34, 211, 238, 0.12), 0 0 30px rgba(34, 211, 238, 0.5);
    }

    .preview-start {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .preview-start .preview-actions {
      margin-top: 0;
      justify-content: flex-end;
    }

    @keyframes preview-scroll {
      from { transform: translateX(0); }
      to { transform: translateX(calc(-50% - 6px)); }
    }

    @keyframes preview-grid {
      from { background-position: 0 0, 0 0; }
      to { background-position: 88px 44px, 44px 88px; }
    }

    @keyframes preview-orbit {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @media (max-width: 980px) {
      .preview-hero {
        min-height: 680px;
        padding-top: 56px;
      }

      .preview-products,
      .preview-proof,
      .preview-features,
      .preview-split {
        grid-template-columns: 1fr;
      }

      .preview-start {
        display: block;
      }

      .preview-start .preview-actions {
        justify-content: flex-start;
        margin-top: 24px;
      }
    }

    @media (max-width: 720px) {
      .preview-hero,
      .preview-section,
      .preview-split,
      .preview-start {
        border-radius: 22px;
        padding: 24px;
      }

      .preview-hero {
        min-height: 640px;
        padding-top: 40px;
      }

      .preview-hero h1 {
        font-size: 2.45rem;
      }

      .preview-marquee {
        bottom: 22px;
      }
    }
  </style>
</BaseLayout>
