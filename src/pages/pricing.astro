---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="价格 | Nexa Relay" description="AI API 中转服务价格说明">
  <section class="panel page-hero">
    <p class="eyebrow">Pricing</p>
    <h1>价格说明</h1>
    <p class="lead">价格页可以独立维护，不需要把所有计费信息都塞进首页。</p>
  </section>
  <section class="panel">
    <div class="pricing-grid">
      <article>
        <h3>免费试用</h3>
        <p class="price">¥0</p>
        <p class="muted">适合验证环境和兼容性。</p>
      </article>
      <article>
        <h3>开发者版</h3>
        <p class="price">¥49</p>
        <p class="price-note">/月起</p>
        <p class="muted">个人开发、工具调用、脚本场景。</p>
      </article>
      <article>
        <h3>团队版</h3>
        <p class="price">¥199</p>
        <p class="price-note">/月起</p>
        <p class="muted">多成员协作、额度和模型策略更灵活。</p>
      </article>
    </div>
  </section>
</BaseLayout>
